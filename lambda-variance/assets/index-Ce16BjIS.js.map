export default "@Y     = λf. (λx. f (x x)) (λx. f (x x))\n@true  = λt. λf. t\n@false = λt. λf. f\n@Z     = λs. λz. z\n@S     = λn. λs. λz. s n\n@pred  = λn. n (λm. m) @Z\n\n@mkLam = λb.     λl. λa. λv. l b\n@mkApp = λf. λx. λl. λa. λv. a f x\n@mkVar = λi.     λl. λa. λv. v i\n\n@natEq = @Y (λr. λm. λn.\n  m (λm'. n (λn'. r m' n') @false)\n    (n (λ_. @false) @true))\n\n@natLt = @Y (λr. λm. λn.\n  n (λn'. m (λm'. r m' n') @true)\n     @false)\n\n@shift1 = @Y (λr. λc. λt.\n  t (λb.     @mkLam (r (@S c) b))\n    (λf. λx. @mkApp (r c f) (r c x))\n    (λi.     @natLt i c (@mkVar i) (@mkVar (@S i))))\n\n@shiftN = @Y (λr. λc. λn. λt.\n  n (λn'. r c n' (@shift1 c t)) t)\n\n@subst = @Y (λr. λj. λarg. λt.\n  t (λb.     @mkLam (r (@S j) arg b))\n    (λf. λx. @mkApp (r j arg f) (r j arg x))\n    (λi.     @natEq i j\n               (@shiftN @Z j arg)\n               (@natLt i j (@mkVar i) (@mkVar (@pred i)))))\n\n@whnf = @Y (λr. λt.\n  t (λb.     @mkLam b)\n    (λf. λx. (λf'. f'\n                (λb.     r (@subst @Z x b))\n                (λ_. λ_. @mkApp f' x)\n                (λ_.     @mkApp f' x))\n             (r f))\n    (λi.     @mkVar i))\n\n@nf = @Y (λr. λt.\n  (λt'. t'\n    (λb.     @mkLam (r b))\n    (λf. λx. @mkApp (r f) (r x))\n    (λi.     @mkVar i))\n  (@whnf t))\n\n@main = @nf\n"