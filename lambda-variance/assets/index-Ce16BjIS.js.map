export default "@Y     = λf. (λx. f (x x)) (λx. f (x x))\n\n\n@TRUE  = λt. λf. t\n@FALSE = λt. λf. f\n\n\n@Z     = λs. λz. z\n@S     = λn. λs. λz. s n\n\n\n@LAM   = λb.     λl. λa. λv. l b\n@APP   = λf. λa. λl. λap. λv. ap f a\n@VAR   = λk.     λl. λa. λv. v k\n\n\n@PRED  = λn. n (λm. m) @Z\n\n\n@LT    = @Y (λlt. λm. λn.\n          n (λn'. m (λm'. lt m' n') @TRUE)\n            @FALSE)\n\n\n@EQ    = @Y (λeq. λm. λn.\n          m (λm'. n (λn'. eq m' n') @FALSE)\n            (n (λ_. @FALSE) @TRUE))\n\n\n@ADD   = @Y (λadd. λm. λn.\n          m (λm'. @S (add m' n)) n)\n\n\n@SHIFT = @Y (λshift. λd. λc. λt.\n          t (λb.     @LAM (shift d (@S c) b))\n            (λf. λa. @APP (shift d c f) (shift d c a))\n            (λk.     (@LT k c) (@VAR k) (@VAR (@ADD k d))))\n\n\n@SUBST = @Y (λsubst. λj. λs. λt.\n          t (λb.     @LAM (subst (@S j) (@SHIFT (@S @Z) @Z s) b))\n            (λf. λa. @APP (subst j s f) (subst j s a))\n            (λk.     (@EQ k j) s ((@LT k j) (@VAR k) (@VAR (@PRED k)))))\n\n\n@main = @Y (λnorm. λt.\n          t (λb.     @LAM (norm b))\n            (λf. λa. (λnf.\n                       nf (λb.      norm (@SUBST @Z a b))\n                          (λf'. λa'. @APP nf (norm a))\n                          (λk.      @APP nf (norm a)))\n                     (norm f))\n            (λk.     @VAR k))\n"