export default "Lambda calculus evaluator. Given a Scott-encoded lambda\nterm using de Bruijn indices, return its beta-normal form\n(also Scott-encoded).\n\nTerm encoding (3-variant Scott):\n  Lam(body)    = λlam.λapp.λvar.lam(body)\n  App(fun,arg) = λlam.λapp.λvar.app(fun, arg)\n  Var(idx)     = λlam.λapp.λvar.var(idx)\nwhere idx is a Scott nat (de Bruijn index).\n\nScott nat: Z = λs.λz.z, S(n) = λs.λz.s(n).\n\nDe Bruijn convention: Var(0) inside one Lam refers to\nthat binder; higher indices reach outer binders or are\nfree. Beta-reduction must handle shifting and\nsubstitution of de Bruijn indices correctly.\n\n@main takes one Term and returns its beta-normal form.\n\n---\n\n@main(λa.λb.λc.c(λd.λe.e))\n\n= λa.λb.λc.c(λd.λe.e)\n\n@main(λa.λb.λc.a(λd.λe.λf.f(λg.λh.h)))\n\n= λa.λb.λc.a(λd.λe.λf.f(λg.λh.h))\n\n@main(λa.λb.λc.b(λd.λe.λf.d(λg.λh.λi.i(λj.λk.k)), λd.λe.λf.f(λg.λh.h)))\n\n= λa.λb.λc.c(λd.λe.e)\n\n@main(λa.λb.λc.b(λd.λe.λf.d(λg.λh.λi.i(λj.λk.k)), λd.λe.λf.d(λg.λh.λi.i(λj.λk.k))))\n\n= λa.λb.λc.a(λd.λe.λf.f(λg.λh.h))\n\n@main(λa.λb.λc.b(λd.λe.λf.f(λg.λh.h), λd.λe.λf.f(λg.λh.g(λi.λj.j))))\n\n= λa.λb.λc.b(λd.λe.λf.f(λg.λh.h), λd.λe.λf.f(λg.λh.g(λi.λj.j)))\n\n@main(λa.λb.λc.b(λd.λe.λf.d(λg.λh.λi.g(λj.λk.λl.l(λm.λn.m(λo.λp.p)))), λd.λe.λf.f(λg.λh.h)))\n\n= λa.λb.λc.a(λd.λe.λf.f(λg.λh.g(λi.λj.j)))\n\n@main(λa.λb.λc.b(λd.λe.λf.e(λg.λh.λi.g(λj.λk.λl.j(λm.λn.λo.o(λp.λq.p(λr.λs.s)))), λg.λh.λi.i(λj.λk.k)), λd.λe.λf.f(λg.λh.g(λi.λj.j))))\n\n= λa.λb.λc.c(λd.λe.e)\n\n@main(λa.λb.λc.b(λd.λe.λf.e(λg.λh.λi.g(λj.λk.λl.j(λm.λn.λo.o(λp.λq.q))), λg.λh.λi.i(λj.λk.k)), λd.λe.λf.f(λg.λh.g(λi.λj.j))))\n\n= λa.λb.λc.c(λd.λe.d(λf.λg.g))\n\n@main(λa.λb.λc.a(λd.λe.λf.e(λg.λh.λi.g(λj.λk.λl.l(λm.λn.n)), λg.λh.λi.i(λj.λk.k))))\n\n= λa.λb.λc.a(λd.λe.λf.f(λg.λh.h))\n\n@main(λa.λb.λc.b(λd.λe.λf.d(λg.λh.λi.h(λj.λk.λl.l(λm.λn.n), λj.λk.λl.l(λm.λn.n))), λd.λe.λf.d(λg.λh.λi.i(λj.λk.k))))\n\n= λa.λb.λc.a(λd.λe.λf.f(λg.λh.h))\n\n"