export default "@Y      = λf. (λx. f (x x)) (λx. f (x x))\n@true   = λa. λb. a\n@false  = λa. λb. b\n@Z      = λs. λz. z\n@S      = λn. λs. λz. s n\n@pred   = λn. n (λm. m) @Z\n\n@geq    = @Y (λgeq_rec. λm. λn.\n           n (λn'. m (λm'. geq_rec m' n') @false) @true)\n\n@natEq  = @Y (λnatEq_rec. λm. λn.\n           n (λn'. m (λm'. natEq_rec m' n') @false)\n             (m (λ_. @false) @true))\n\n@natAdd = @Y (λnatAdd_rec. λm. λn.\n           n (λn'. @S (natAdd_rec m n')) m)\n\n@mkLam  = λbody. λlam. λapp. λvar. lam body\n@mkApp  = λf. λa. λlam. λapp. λvar. app f a\n@mkVar  = λi. λlam. λapp. λvar. var i\n\n@shift  = @Y (λshift_rec. λt. λc. λd.\n           t (λbody. @mkLam (shift_rec body (@S c) d))\n             (λf. λa. @mkApp (shift_rec f c d) (shift_rec a c d))\n             (λi. @geq i c (@mkVar (@natAdd i d)) (@mkVar i)))\n\n@subst  = @Y (λsubst_rec. λt. λj. λs.\n           t (λbody. @mkLam (subst_rec body (@S j) (@shift s @Z (@S @Z))))\n             (λf. λa. @mkApp (subst_rec f j s) (subst_rec a j s))\n             (λi. (@natEq i j) s\n                    (@geq i (@S j) (@mkVar (@pred i)) (@mkVar i))))\n\n@eval   = @Y (λeval_rec. λt.\n           t (λbody. @mkLam (eval_rec body))\n             (λf. λa.\n               (λnf.\n                 nf (λbody. eval_rec (@subst body @Z a))\n                    (λ_. λ_. @mkApp nf (eval_rec a))\n                    (λ_.    @mkApp nf (eval_rec a)))\n               (eval_rec f))\n             (λi. @mkVar i))\n\n@main  = @eval\n"