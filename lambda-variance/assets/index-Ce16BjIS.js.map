export default "@Y   = λf. (λx. f (x x)) (λx. f (x x))\n\n\n@T   = λt. λf. t\n@F   = λt. λf. f\n\n\n@Z   = λs. λz. z\n@S   = λn. λs. λz. s n\n\n\n@pred = λn. n (λm. m) @Z\n\n\n@eq  = @Y (λr. λn. λm.\n        n (λn'. m (λm'. r n' m') @F)\n          (m (λm'. @F) @T))\n\n\n@lt  = @Y (λr. λn. λm.\n        m (λm'. n (λn'. r n' m') @T) @F)\n\n\n@add = @Y (λr. λn. λm.\n        n (λn'. @S (r n' m)) m)\n\n\n@Lam = λb.    λl. λa. λv. l b\n@App = λf. λx. λl. λa. λv. a f x\n@Var = λi.    λl. λa. λv. v i\n\n\n\n@shift = @Y (λr. λt. λa. λc.\n          t (λb.     @Lam (r b a (@S c)))\n            (λf. λx. @App (r f a c) (r x a c))\n            (λi.     @lt i c\n                       (@Var i)\n                       (@Var (@add i a))))\n\n\n\n@subst = @Y (λr. λt. λd. λs.\n          t (λb.     @Lam (r b (@S d) s))\n            (λf. λx. @App (r f d s) (r x d s))\n            (λi.     @eq i d\n                       (@shift s d @Z)\n                       (@lt i d\n                         (@Var i)\n                         (@Var (@pred i)))))\n\n\n@norm = @Y (λr. λt.\n         t (λb.     @Lam (r b))\n           (λf. λx.\n             (λnf.\n               nf\n                 (λb.         r (@subst b @Z x))\n                 (λf'. λx'.   @App nf (r x))\n                 (λi.         @App nf (r x)))\n             (r f))\n           (λi.     @Var i))\n\n@main = @norm\n"