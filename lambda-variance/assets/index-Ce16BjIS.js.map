export default "@Y = λf. (λx. f (x x)) (λx. f (x x))\n\n@Z   = λs. λz. z\n@S   = λn. λs. λz. s n\n@T   = λt. λf. t\n@F   = λt. λf. f\n\n@Lam = λb.    λl. λa. λv. l b\n@App = λf. λx. λl. λa. λv. a f x\n@Var = λi.    λl. λa. λv. v i\n\n@natPred = λn. n (λp. p) @Z\n\n@natEq = @Y (λr. λm. λn.\n  m (λm'. n (λn'. r m' n') @F)\n    (n (λn'. @F) @T))\n\n@natLt = @Y (λr. λm. λn.\n  n (λn'. m (λm'. r m' n') @T)\n    @F)\n\n@shift = @Y (λr. λt. λc.\n  t (λb.     @Lam (r b (@S c)))\n    (λf. λx.  @App (r f c) (r x c))\n    (λi.     @natLt i c (@Var i) (@Var (@S i))))\n\n@subst = @Y (λr. λt. λj. λs.\n  t (λb.     @Lam (r b (@S j) (@shift s @Z)))\n    (λf. λx.  @App (r f j s) (r x j s))\n    (λi.     @natEq i j s (@natLt i j (@Var i) (@Var (@natPred i)))))\n\n@nf = @Y (λr. λt.\n  t (λb.     @Lam (r b))\n    (λf. λx.  (λf'.\n                 f' (λb.     r (@subst b @Z x))\n                   (λg. λy.  @App f' (r x))\n                   (λi.     @App f' (r x)))\n               (r f))\n    (λi.     @Var i))\n\n@main = @nf\n"